#!/usr/bin/env bash
# Control an OpenVPN connection managed by Viscosity using credentials from 1Password.
# Retrieves username, password and live TOTP automatically — no manual typing required.
# Uses macOS Accessibility (System Events) to fill Viscosity's credential dialog.
#
# Designed to be called via a shell alias that supplies --item, --split and --full-conn,
# keeping all company-specific names out of version control.
#
# One-time setup: grant Accessibility access to your terminal app in
#   System Settings → Privacy & Security → Accessibility
#
# Requires:
#   - 1Password CLI (brew install 1password-cli)
#   - jq            (brew install jq)
#   - Viscosity with both profiles imported
#
# Examples (set up via alias in .aliases.local):
#   vpn                  # Connect using split-tunnel profile (default)
#   vpn --full           # Connect using full-tunnel profile (all traffic via VPN)
#   vpn --down           # Disconnect all connections
#   vpn --status         # Show connection status of both profiles

set -o errexit
set -o pipefail
set -o nounset

readonly CONNECT_TIMEOUT=30

log_info() {
  local -r green='\033[0;32m'
  local -r nc='\033[0m'
  printf "%b[INFO]%b %s\n" "${green}" "${nc}" "${1}"
}

log_error() {
  local -r red='\033[0;31m'
  local -r nc='\033[0m'
  printf "%b[ERROR]%b %s\n" "${red}" "${nc}" "${1}" >&2
}

log_warn() {
  local -r yellow='\033[1;33m'
  local -r nc='\033[0m'
  printf "%b[WARN]%b %s\n" "${yellow}" "${nc}" "${1}" >&2
}

usage() {
  cat <<EOF
Usage: ${0##*/} --item ITEM --split CONN --full-conn CONN [ACTION]

Required configuration (typically supplied via alias):
    --item STRING       1Password item name holding VPN credentials and TOTP
    --split STRING      Viscosity connection name for the split-tunnel profile
    --full-conn STRING  Viscosity connection name for the full-tunnel profile

Actions:
    -f, --full          Connect using full-tunnel profile (all traffic via VPN)
    -d, --down          Disconnect all connections
    -s, --status        Show connection status of both profiles
    -h, --help          Show this help message

Default action (no flag): connect using split-tunnel profile

Example alias in .aliases.local:
    alias vpn='vpn-connect --item "My VPN" --split "VPN-Split" --full-conn "VPN-Full"'
EOF
}

check_prerequisites() {
  local -r op_item="${1}"
  local -r conn_split="${2}"
  local -r conn_full="${3}"

  local missing=()
  [[ -z "${op_item}" ]] && missing+=("--item")
  [[ -z "${conn_split}" ]] && missing+=("--split")
  [[ -z "${conn_full}" ]] && missing+=("--full-conn")

  if ((${#missing[@]} > 0)); then
    log_error "Missing required parameters: ${missing[*]}"
    usage
    exit 1
  fi

  if ! command -v op &>/dev/null; then
    log_error "1Password CLI not found. Install with: brew install 1password-cli"
    exit 1
  fi

  if ! command -v jq &>/dev/null; then
    log_error "jq not found. Install with: brew install jq"
    exit 1
  fi

  if ! pgrep -x Viscosity &>/dev/null; then
    log_error "Viscosity is not running. Please launch Viscosity first."
    exit 1
  fi
}

# Returns Viscosity's state string for a connection: "Connected", "Connecting", or "Disconnected".
# Uses the AppleScript dictionary's state property — more reliable than timeConnected for state checks.
get_connection_state() {
  local -r conn="${1}"
  osascript - "${conn}" <<'EOF' 2>/dev/null || true
on run argv
  tell application "Viscosity"
    repeat with c in connections
      if name of c is (item 1 of argv) then
        return state of c
      end if
    end repeat
    return "Disconnected"
  end tell
end run
EOF
}

# Returns the connected-for duration string ("0:05:42"), or empty string if not connected.
get_connection_time() {
  local -r conn="${1}"
  osascript - "${conn}" <<'EOF' 2>/dev/null || true
on run argv
  tell application "Viscosity"
    repeat with c in connections
      if name of c is (item 1 of argv) then
        return timeConnected of c
      end if
    end repeat
    return ""
  end tell
end run
EOF
}

connection_state() {
  local -r conn="${1}"
  local state time
  state=$(get_connection_state "${conn}")
  case "${state}" in
  Connected)
    time=$(get_connection_time "${conn}")
    if [[ -n "${time}" ]]; then
      printf "Connected (%s)" "${time}"
    else
      printf "Connected"
    fi
    ;;
  Connecting) printf "Connecting..." ;;
  *) printf "Disconnected" ;;
  esac
}

# Fills Viscosity's credential dialog via macOS Accessibility.
# Credentials are passed via environment variables (not argv) to keep them out of the process list.
# Requires the terminal app to have Accessibility permission granted in System Settings.
fill_credentials() {
  local -r user="${1}"
  local -r pass="${2}"

  VPN_CRED_USER="${user}" VPN_CRED_PASS="${pass}" osascript <<'APPLESCRIPT'
on run
  set theUser to system attribute "VPN_CRED_USER"
  set thePass to system attribute "VPN_CRED_PASS"

  tell application "System Events"
    tell process "Viscosity"
      set frontmost to true
      -- Wait up to 15s for the credential dialog to appear
      repeat 30 times
        if (count windows) > 0 then exit repeat
        delay 0.5
      end repeat
      if (count windows) is 0 then error "Credential dialog did not appear"

      -- Find the dialog window: the one that contains both a regular and a secure text field.
      -- This avoids assuming window order if Viscosity has other windows open (e.g. preferences).
      set theWindow to missing value
      repeat with w in windows
        set hasUser to false
        set hasPass to false
        repeat with tf in text fields of w
          if role description of tf is "secure text field" then
            set hasPass to true
          else
            set hasUser to true
          end if
        end repeat
        if hasUser and hasPass then
          set theWindow to w
          exit repeat
        end if
      end repeat
      if theWindow is missing value then error "Could not find credential dialog window"

      set userField to missing value
      set passField to missing value
      repeat with tf in text fields of theWindow
        if role description of tf is "secure text field" then
          set passField to tf
        else
          set userField to tf
        end if
      end repeat
      if userField is missing value then error "Could not find username field"
      if passField is missing value then error "Could not find password field"

      -- Fill username (set value works reliably for non-secure text fields)
      set focused of userField to true
      delay 0.2
      set value of userField to theUser

      -- Fill password (set value is blocked for secure fields — keystroke required)
      set focused of passField to true
      delay 0.2
      keystroke "a" using {command down}
      keystroke thePass

      delay 0.3
      click button "OK" of theWindow
    end tell
  end tell
end run
APPLESCRIPT
}

wait_for_connected() {
  local -r conn="${1}"
  local i=0
  log_info "Waiting for connection..."
  while [[ "${i}" -lt "${CONNECT_TIMEOUT}" ]]; do
    if [[ "$(get_connection_state "${conn}")" == "Connected" ]]; then
      return 0
    fi
    sleep 1
    i=$((i + 1))
  done
  log_error "Timed out after ${CONNECT_TIMEOUT}s. Check Viscosity logs for details."
  return 1
}

connect() {
  local -r op_item="${1}"
  local -r conn="${2}"

  if [[ "$(get_connection_state "${conn}")" == "Connected" ]]; then
    log_info "Already connected to ${conn}."
    return 0
  fi

  log_info "Fetching credentials from 1Password..."
  local creds user pass
  creds=$(op item get "${op_item}" --fields label=username,label=password --format json --reveal)
  user=$(printf '%s' "${creds}" | jq -r '.[] | select(.label=="username") | .value')
  pass=$(printf '%s' "${creds}" | jq -r '.[] | select(.label=="password") | .value')
  creds=""

  log_info "Connecting to ${conn}..."
  osascript - "${conn}" <<'EOF'
on run argv
  tell application "Viscosity" to connect (item 1 of argv)
end run
EOF

  # Fetch OTP after triggering the connection to minimise the gap before use.
  # TOTP codes rotate every 30s; fetching early risks expiry during slow dialog appearance.
  log_info "Fetching OTP from 1Password..."
  local otp
  otp=$(op item get "${op_item}" --otp)

  log_info "Filling credentials..."
  fill_credentials "${user}" "${pass}${otp}"
  user="" pass="" otp=""

  wait_for_connected "${conn}"
  log_info "Connected to ${conn}."
}

disconnect_all() {
  osascript -e 'tell application "Viscosity" to disconnectall'
  log_info "All VPN connections disconnected."
}

status() {
  local -r conn_split="${1}"
  local -r conn_full="${2}"
  printf '%-38s %s\n' "${conn_split}" "$(connection_state "${conn_split}")"
  printf '%-38s %s\n' "${conn_full}" "$(connection_state "${conn_full}")"
}

main() {
  local op_item=""
  local conn_split=""
  local conn_full=""
  local action="connect-split"

  while (($#)); do
    case "${1}" in
    --item)
      [[ -z "${2:-}" ]] && {
        log_error "Missing value for --item"
        exit 1
      }
      op_item="${2}"
      shift 2
      ;;
    --split)
      [[ -z "${2:-}" ]] && {
        log_error "Missing value for --split"
        exit 1
      }
      conn_split="${2}"
      shift 2
      ;;
    --full-conn)
      [[ -z "${2:-}" ]] && {
        log_error "Missing value for --full-conn"
        exit 1
      }
      conn_full="${2}"
      shift 2
      ;;
    -f | --full)
      action="connect-full"
      shift
      ;;
    -d | --down)
      action="down"
      shift
      ;;
    -s | --status)
      action="status"
      shift
      ;;
    -h | --help)
      usage
      exit 0
      ;;
    *)
      log_error "Unknown option: '${1}'"
      usage
      exit 1
      ;;
    esac
  done

  trap 'log_warn "Interrupted — run with --down to clean up if Viscosity is still connecting."' INT TERM

  case "${action}" in
  connect-split)
    check_prerequisites "${op_item}" "${conn_split}" "${conn_full}"
    connect "${op_item}" "${conn_split}"
    ;;
  connect-full)
    check_prerequisites "${op_item}" "${conn_split}" "${conn_full}"
    connect "${op_item}" "${conn_full}"
    ;;
  down)
    if ! pgrep -x Viscosity &>/dev/null; then
      log_warn "Viscosity is not running."
      exit 0
    fi
    disconnect_all
    ;;
  status)
    check_prerequisites "${op_item}" "${conn_split}" "${conn_full}"
    status "${conn_split}" "${conn_full}"
    ;;
  esac
}

main "$@"
